# ── App ───────────────────────────────────────────────────────
APP_NAME="Nauman Tariq Portfolio API"
APP_ENV=development
# development | production
DEBUG=True

# ── Database (Neon PostgreSQL) ────────────────────────────────
# Format: postgresql+psycopg2://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+psycopg2://user:password@ep-xxxx.neon.tech/portfolio?sslmode=require

# ── JWT Auth ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Admin ─────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# ── Cloudinary ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Resend Email ──────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=portfolio@yourdomain.com
RESEND_TO_EMAIL=nauman@youremail.com

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://yourdomain.com
